algoritmo "Meu número premiado!"

var
  numero, soma: inteiro
inicio
  soma <- 0
  
  escreva("Digite um número (ou 0 para sair): ")
  leia(numero)

  enquanto (numero <> 0) faca
    soma <- soma + numero
    
    escreva("Digite o próximo número (ou 0 para sair): ")
    leia(numero)
  fimenquanto

  escreval("A soma total de todos os números digitados é: ", soma)

fimalgoritmo



